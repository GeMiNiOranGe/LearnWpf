<Page
  x:Class="Source.BindingPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Source"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  x:Name="bindingPage"
  Title="BindingPage"
  d:DesignHeight="450"
  d:DesignWidth="800"
  mc:Ignorable="d">

  <StackPanel Margin="16,8">
    <TextBlock x:Name="windowWidthTextBlock" Text="Window width" />
    <TextBox x:Name="windowWidthTextBox" />

    <TextBlock x:Name="windowHeightTextBlock" Text="Window height" />
    <TextBox x:Name="windowHeightTextBox" />

    <TextBlock x:Name="bindingPageWidthTextBlock" Text="Binding page width" />
    <TextBox x:Name="bindingPageWidthTextBox" Text="{Binding ElementName=bindingPage, Path=Width}" />

    <TextBlock x:Name="bindingPageHeightTextBlock" Text="Binding page height" />
    <TextBox x:Name="bindingPageHeightTextBox" Text="{Binding ElementName=bindingPage, Path=Height}" />

    <TextBlock x:Name="sourceTextBlock" Text="Source message" />
    <TextBox x:Name="sourceTextBox" />

    <TextBlock x:Name="destinationTextBlock" Text="Destination message" />
    <TextBox x:Name="destinationTextBox" Text="{Binding ElementName=sourceTextBox, Path=Text}" />

    <TextBlock x:Name="lengthTextBlock" Text="Message length" />
    <TextBox x:Name="lengthTextBox" Text="{Binding ElementName=sourceTextBox, Path=Text.Length, Mode=OneWay}" />
  </StackPanel>
</Page>
