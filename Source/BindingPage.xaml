<Page
  x:Class="Source.BindingPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Source"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  x:Name="bindingPage"
  Title="BindingPage"
  d:DesignHeight="450"
  d:DesignWidth="800"
  mc:Ignorable="d">
  <Page.Resources>
    <Style x:Key="LastFieldRow" TargetType="Grid">
      <Setter Property="Margin" Value="0,8" />
    </Style>

    <Style TargetType="Grid">
      <Setter Property="Margin" Value="0,8,0,0" />
    </Style>

    <Style TargetType="TextBlock">
      <Setter Property="Margin" Value="16,0,8,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Grid.Column" Value="1" />
      <Setter Property="Margin" Value="0,0,16,0" />
    </Style>
  </Page.Resources>

  <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <StackPanel Grid.IsSharedSizeScope="True">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="windowWidthTextBlock" Text="Window width" />
        <TextBox x:Name="windowWidthTextBox" />
      </Grid>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="windowHeightTextBlock" Text="Window height" />
        <TextBox x:Name="windowHeightTextBox" />
      </Grid>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="bindingPageWidthTextBlock" Text="Binding page width" />
        <TextBox x:Name="bindingPageWidthTextBox" Text="{Binding ElementName=bindingPage, Path=ActualWidth, Mode=OneWay}" />
      </Grid>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="bindingPageHeightTextBlock" Text="Binding page height" />
        <TextBox x:Name="bindingPageHeightTextBox" Text="{Binding ElementName=bindingPage, Path=ActualHeight, Mode=OneWay}" />
      </Grid>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="sourceTextBlock" Text="Source message" />
        <TextBox x:Name="sourceTextBox" />
      </Grid>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="destinationTextBlock" Text="Destination message" />
        <TextBox x:Name="destinationTextBox" Text="{Binding ElementName=sourceTextBox, Path=Text}" />
      </Grid>

      <Grid Style="{StaticResource LastFieldRow}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="lengthTextBlock" Text="Message length" />
        <TextBox x:Name="lengthTextBox" Text="{Binding ElementName=sourceTextBox, Path=Text.Length, Mode=OneWay}" />
      </Grid>
    </StackPanel>
  </ScrollViewer>
</Page>
