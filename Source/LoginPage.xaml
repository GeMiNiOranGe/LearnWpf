<Page
  x:Class="Source.LoginPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Source"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Title="LoginPage"
  d:DesignHeight="450"
  d:DesignWidth="800"
  Background="#FFC080"
  mc:Ignorable="d">
  <StackPanel
    x:Name="mainStackPanel"
    Width="200"
    HorizontalAlignment="Center"
    VerticalAlignment="Center">
    <TextBlock Text="Username" />
    <TextBox x:Name="usernameTextBox" Margin="0,0,0,8" />

    <TextBlock Text="Password" />
    <PasswordBox x:Name="passwordBox" Margin="0,0,0,24" />

    <Button
      Padding="24,12"
      Click="LoginButton_Click"
      Content="Login">
      <Button.Template>
        <ControlTemplate TargetType="Button">
          <Border Background="LightBlue" CornerRadius="8">
            <ContentPresenter
              Margin="{TemplateBinding Padding}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Button.Template>
    </Button>
  </StackPanel>
</Page>
