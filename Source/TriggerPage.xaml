<Page
  x:Class="Source.TriggerPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Source"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Title="TriggerPage"
  d:DesignHeight="450"
  d:DesignWidth="800"
  mc:Ignorable="d">
  <StackPanel>
    <!--  Data trigger  -->
    <StackPanel HorizontalAlignment="Center">
      <CheckBox
        x:Name="checkBox"
        HorizontalAlignment="Center"
        Content="Click the checkbox to see the magic!" />
      <TextBlock
        Margin="0,16,0,0"
        HorizontalAlignment="Center"
        FontSize="28">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Text" Value="A purple text" />
            <Setter Property="Foreground" Value="Purple" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding ElementName=checkBox, Path=IsChecked}" Value="True">
                <Setter Property="Text" Value="An orange text" />
                <Setter Property="Foreground" Value="Orange" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
    </StackPanel>

    <Rectangle
      Height="4"
      Margin="0,8"
      Fill="Black" />

    <!--  Property trigger  -->
    <TextBlock
      HorizontalAlignment="Center"
      FontSize="28"
      Text="Hover your mouse over this text">
      <TextBlock.Style>
        <Style TargetType="TextBlock">
          <Setter Property="Foreground" Value="Blue" />
          <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Foreground" Value="Red" />
              <Setter Property="TextDecorations" Value="Underline" />
            </Trigger>
          </Style.Triggers>
        </Style>
      </TextBlock.Style>
    </TextBlock>

    <Rectangle
      Height="4"
      Margin="0,8"
      Fill="Black" />

    <!--  Event trigger  -->
    <TextBlock
      HorizontalAlignment="Center"
      FontSize="28"
      Text="Hover your mouse over this text again">
      <TextBlock.Style>
        <Style TargetType="TextBlock">
          <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
              <BeginStoryboard>
                <Storyboard>
                  <!--  Note: <[Datatype]Animation>: Double is datatype  -->
                  <DoubleAnimation
                    Storyboard.TargetProperty="FontSize"
                    To="32"
                    Duration="0:0:0.125" />
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>

            <EventTrigger RoutedEvent="MouseLeave">
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation
                    Storyboard.TargetProperty="FontSize"
                    To="28"
                    Duration="0:0:0.125" />
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </Style.Triggers>
        </Style>
      </TextBlock.Style>
    </TextBlock>
  </StackPanel>
</Page>
