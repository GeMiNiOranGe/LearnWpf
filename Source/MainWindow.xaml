<Window
  x:Class="Source.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Source"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Title="MainWindow"
  Width="800"
  Height="450"
  mc:Ignorable="d">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0">
      <Button
        x:Name="messageButton"
        Click="MessageButton_Click"
        Content="Message page" />
      <Button
        x:Name="loginButton"
        Click="LoginButton_Click"
        Content="Login page" />
      <Button
        x:Name="bindingButton"
        Click="BindingButton_Click"
        Content="Binding page" />
    </StackPanel>

    <Frame x:Name="mainFrame" Grid.Column="1" />
  </Grid>
</Window>
