<Page
  x:Class="Source.ObservablePage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:Source"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Title="ObservablePage"
  d:DataContext="{d:DesignInstance Type=local:ObservablePage,
                                   IsDesignTimeCreatable=True}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  mc:Ignorable="d">
  <Page.Resources>
    <local:AgeConverter x:Key="AgeConverter" />
  </Page.Resources>

  <StackPanel>
    <TextBox Text="{Binding DataValue, UpdateSourceTrigger=PropertyChanged}" />
    <TextBlock Text="{Binding DataValue}" />

    <Rectangle
      Height="4"
      Margin="0,8"
      Fill="Black" />

    <TextBlock Text="Your birthday:" />
    <DatePicker x:Name="birthdayDatePicker" />

    <TextBlock Text="Your age:" />
    <TextBlock Text="{Binding ElementName=birthdayDatePicker, Path=SelectedDate, Converter={StaticResource AgeConverter}}" />
  </StackPanel>
</Page>
